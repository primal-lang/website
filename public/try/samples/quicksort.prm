/*
  Input: a list of numbers
  Output: the list sorted in ascending order using the quicksort algorithm
*/

quicksort(list) =
    if (list.isEmpty(list))
        []
    else
        let
            pivot = list.first(list),
            rest = list.rest(list)
        in
            quicksort(list.filter(rest, (x) -> x < pivot)) + pivot + quicksort(list.filter(rest, (x) -> x >= pivot))

main() = quicksort([38, 27, 43, 3, 9])